{
  "name": "cat-tools-activate-pipeline-tests",
  "private": true,
  "description": "E2E tests for Content Activation Pipeline",
  "scripts": {
    "test:e2e": "npx playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:headed": "npx playwright test --config=tests/e2e/playwright.config.ts --headed",
    "test:e2e:report": "npx playwright show-report TestOutput/e2e/html-report",
    "test:schema": "npx playwright test --config=tests/e2e/playwright.config.ts schema-validation",
    "test:app": "npx playwright test --config=tests/e2e/playwright.config.ts code-app"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "dotenv": "^16.4.0"
  }
}
